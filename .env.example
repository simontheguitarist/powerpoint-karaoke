DATABASE_URL=./pk.db
BETTER_AUTH_SECRET=replace-with-long-random-string
BETTER_AUTH_URL=http://localhost:3000
BETTER_AUTH_TRUSTED_ORIGINS=http://127.0.0.1:3000,http://localhost:3000
STORAGE_DIR=./storage
SOFFICE_PATH=/Applications/LibreOffice.app/Contents/MacOS/soffice
PDFTOPPM_PATH=/opt/homebrew/bin/pdftoppm

# Google OAuth (optional) — get credentials from https://console.cloud.google.com/apis/credentials
# Authorized redirect URI: http://localhost:3000/api/auth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
